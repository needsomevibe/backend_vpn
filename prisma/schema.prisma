generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum VpnAccountStatus {
  ACTIVE
  DISABLED
  EXPIRED
  LIMITED
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

model User {
  id             String         @id @default(uuid())
  email          String         @unique
  passwordHash   String?
  appleSubject   String?        @unique
  authProvider   String         @default("email")
  status         UserStatus     @default(ACTIVE)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  vpnAccount     VpnAccount?
  subscriptions  Subscription[]
  payments       Payment[]
  devices        Device[]
  refreshTokens  RefreshToken[]

  @@index([status])
  @@index([authProvider])
}

model VpnAccount {
  id                 String           @id @default(uuid())
  userId             String           @unique
  remnawaveUuid      String           @unique
  remnawaveShortUuid String?
  username           String           @unique
  status             VpnAccountStatus @default(ACTIVE)
  trafficLimitBytes  BigInt
  usedTrafficBytes   BigInt           @default(0)
  expiresAt          DateTime
  subscriptionUrl    String
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([status])
}

model Plan {
  id             String         @id @default(uuid())
  name           String         @unique
  trafficLimitGb Int
  deviceLimit    Int
  durationDays   Int
  priceCents     Int
  currency       String         @default("USD")
  isDefault      Boolean        @default(false)
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  subscriptions  Subscription[]

  @@index([isActive, isDefault])
}

model Subscription {
  id                     String             @id @default(uuid())
  userId                 String
  planId                 String
  status                 SubscriptionStatus @default(TRIALING)
  startedAt              DateTime           @default(now())
  expiresAt              DateTime
  provider               String             @default("internal")
  providerSubscriptionId String?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  user                   User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan                   Plan               @relation(fields: [planId], references: [id])

  @@index([userId, status])
  @@index([expiresAt, status])
}

model Payment {
  id                String        @id @default(uuid())
  userId            String
  provider          String
  amountCents       Int
  currency          String        @default("USD")
  status            PaymentStatus @default(PENDING)
  providerPaymentId String?
  createdAt         DateTime      @default(now())
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, provider])
  @@index([providerPaymentId])
}

model Device {
  id         String   @id @default(uuid())
  userId     String
  deviceId   String
  platform   String   @default("ios")
  name       String?
  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceId])
  @@index([deviceId])
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String
  deviceId  String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}
